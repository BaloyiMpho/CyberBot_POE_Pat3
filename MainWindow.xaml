<Window x:Class="CyberBot_POE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CyberBot_POE"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Foreground="#FFFFFFFF">

    <Grid Background="#FFFFFFFF">
        <Border 
        CornerRadius="10" 
        Width="672" 
        Height="392" 
        Padding="15"
        VerticalAlignment="Center" 
        HorizontalAlignment="Center" 
        Margin="-176,0,-192,-40" Background="#FF0CD8DF">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.3" Direction="270" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Chat" Foreground="White" Opacity="0.7" FontWeight="SemiBold" TextAlignment="Center"/>
                    <Button x:Name="Game" Content="Game" HorizontalAlignment="Left" Margin="49,0,0,0" Background="#FF71BEF9" Foreground="#FFF9F9F9" Height="20" VerticalAlignment="Bottom" Width="85" RenderTransformOrigin="0.5,0.5" Click="Game_Click">
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="-0.136"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Button.RenderTransform>
                    </Button>
                </Grid>

                <!-- Chat Panel -->

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="chatPanel" Margin="8" Background="#FFF1F9F9"/>
                </ScrollViewer>

                <!-- Input Area -->
                <Border Grid.Row="2" CornerRadius="24" Padding="10,5" Background="#FFCBCBCC">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="MessageInput"
                             BorderThickness="0"
                             Foreground="Black"
                             Text="Send a message..." 
                             VerticalAlignment="Center" Background="#FFAFAFAF" TextChanged="inputMessage_TextChanged" />

                        <Button Content="➤" 
                            Foreground="White" 
                            Opacity="0.5"
                            HorizontalAlignment="Left" 
                            VerticalAlignment="Center" 
                            x:Name="Button2" 
                            Click="Button2_Click" Background="#FF909292" Margin="606,0,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>