<Page x:Class="CyberBot_POE.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="GamePage">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F2027"/>
                <GradientStop Color="#203A43" Offset="0.5"/>
                <GradientStop Color="#2C5364" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="650"
                Height="420"
                Background="#1E2A38"
                CornerRadius="15"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#3A6EA5"
                BorderThickness="2">

            <Grid>

                <!-- Title -->
                <TextBlock Text="C# Quiz"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <!-- Score -->
                <TextBlock Text="{Binding ScoreString}"
                           Foreground="LightBlue"
                           FontSize="16"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"/>

                <!-- Question -->
                <TextBlock Text="{Binding Question}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,60,0,0"
                           TextWrapping="Wrap"/>

                <!-- Options -->
                <StackPanel Margin="0,120,0,0">

                    <RadioButton x:Name="opt1"
                                 Content="{Binding Option1}"
                                 Foreground="White"/>

                    <RadioButton x:Name="opt2"
                                 Content="{Binding Option2}"
                                 Foreground="White"/>

                    <RadioButton x:Name="opt3"
                                 Content="{Binding Option3}"
                                 Foreground="White"/>

                    <RadioButton x:Name="opt4"
                                 Content="{Binding Option4}"
                                 Foreground="White"/>
                </StackPanel>

                <!-- Submit -->
                <Button x:Name="MyButton"
                        Content="Submit Answer"
                        Width="160"
                        Height="35"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="#3A6EA5"
                        Foreground="White"
                        Click="Button1_Click"/>

                <!-- Back -->
                <Button Content="Back"
                        Width="100"
                        Height="30"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="#607D8B"
                        Foreground="White"
                        Click="Button_Click"/>

            </Grid>
        </Border>
    </Grid>
</Page>